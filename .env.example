# Saku environment variables.
#
# Copy this to `.env.local` (gitignored) and fill in the Supabase values from
# your project's Dashboard → Settings → API. LEAVE THEM BLANK for local dev to
# keep using the file-based store (history.json / lists.json) with no auth — the
# app auto-selects the Supabase backend only when these are set.

# Public: safe to expose to the browser (protected by Row-Level Security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional, server-only. Not needed for normal use — every read/write runs as
# the signed-in user under RLS. Only set this if a future admin/maintenance
# script needs to bypass RLS. NEVER expose it to the browser.
# SUPABASE_SERVICE_ROLE_KEY=
